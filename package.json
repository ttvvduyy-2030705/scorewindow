    "@react-native/eslint-config": "0.75.5",
    "@react-native/metro-config": "^0.84.1",
    "@rnx-kit/jest-preset": "^0.1.17",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "8.57.0",
    "metro-react-native-babel-preset": "0.77.0"
  },
