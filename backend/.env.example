PORT=10000
NODE_ENV=production
NODE_VERSION=22

# Render/VPS production HTTPS domain. Nếu domain Render thật khác thì đổi đồng bộ 2 dòng APP_BASE_URL và GOOGLE_REDIRECT_URI.
APP_BASE_URL=https://aplus-live-backend.onrender.com
APP_CALLBACK_URL=aplusscore://oauth/callback

# Token storage: trên Render nên dùng Persistent Disk mount vào /var/data hoặc đổi sang database.
DATA_DIR=/var/data
# TOKEN_STORE_PATH=/var/data/tokens.json

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://aplus-live-backend.onrender.com/auth/google/callback

# Facebook/TikTok giữ lại cho sau, không dùng cho ưu tiên YouTube release hiện tại.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://aplus-live-backend.onrender.com/auth/facebook/callback
FACEBOOK_GRAPH_VERSION=v25.0

TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=https://aplus-live-backend.onrender.com/auth/tiktok/callback

# Aplus Pro / Google Play Billing server verification.
GOOGLE_PLAY_PACKAGE_NAME=com.aplus.score
APLUS_PRO_PRODUCT_ID=aplus_pro
BILLING_STORE_PATH=/var/data/billing.json
BILLING_TRANSFER_LIMIT=2
BILLING_TRANSFER_WINDOW_DAYS=30

# Cách 1: dán nguyên JSON service account của Google Play Developer API vào biến này.
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}

# Cách 2: hoặc base64 JSON service account rồi dán vào đây để dễ cấu hình Render hơn.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=

# Cách 3: hoặc tách riêng email/private key.
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY=
